#!/usr/bin/env bash
#
# claudeview — Claude Code in the current project, with ClaudeView attached.
#
#   claudeview                  # plugin + dashboard + --dangerously-skip-permissions
#   claudeview --safe           # ...without skip-permissions, for when you want the prompts
#   claudeview --no-dashboard   # plugin only; no server, no browser
#
# Any other flags pass straight through to `claude`.
#
# Note on --dangerously-skip-permissions: it is ON by default here because this is a
# personal, single-operator entrypoint and being prompted for every read on a 30k-LOC repo
# is untenable. It does mean an agent can run anything without asking. `--safe` turns it off
# for one invocation; nothing else about the session changes.
#
set -euo pipefail

# Default to wherever this script actually lives, so the checkout can be moved to another
# machine (or just another directory) without editing anything. CLAUDEVIEW_ROOT still wins.
#
# The symlink walk is load-bearing. If this was linked onto your PATH rather than having the
# checkout's own bin/ added to it, BASH_SOURCE is the *link*, not its target — bash doesn't
# resolve it. Walking up from there lands on the link's parent (~/.local for a
# ~/.local/bin/claudeview link) and we'd refuse to start, pointing at a directory that has
# nothing to do with the checkout.
SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do
  LINK="$(readlink "$SELF")"
  [[ "$LINK" == /* ]] && SELF="$LINK" || SELF="$(cd -P "$(dirname "$SELF")" && pwd)/$LINK"
done
CV_ROOT="${CLAUDEVIEW_ROOT:-$(cd -P "$(dirname "$SELF")/.." && pwd)}"
REPO="$(pwd)"

if [[ ! -f "$CV_ROOT/.claude-plugin/plugin.json" ]]; then
  echo "claudeview: no plugin at $CV_ROOT (set CLAUDEVIEW_ROOT)" >&2
  exit 1
fi

# One dashboard per project, on a STABLE port derived from the repo path.
#
# Stability matters more than it sounds: a dashboard you can keep in a pinned browser tab is
# one you actually glance at. One whose address moves every session is one you stop opening.
PORT=$(( 7800 + $(printf '%s' "$REPO" | cksum | cut -d' ' -f1) % 180 ))

WANT_DASH=1
SKIP_PERMS=1
ARGS=()
for a in "$@"; do
  case "$a" in
    --no-dashboard) WANT_DASH=0 ;;
    --safe)         SKIP_PERMS=0 ;;
    *)              ARGS+=("$a") ;;
  esac
done

[[ "$SKIP_PERMS" == "1" ]] && ARGS+=(--dangerously-skip-permissions)

if [[ "$WANT_DASH" == "1" ]]; then
  if curl -sf -m 1 "http://localhost:$PORT/api/pulse" >/dev/null 2>&1; then
    echo "claudeview: dashboard already up → http://localhost:$PORT"
  elif [[ -f "$CV_ROOT/packages/server/dist/server.js" ]]; then
    # Detached. Its failure must never block the session it only observes.
    CLAUDE_PROJECT_DIR="$REPO" CV_PORT="$PORT" \
      nohup node "$CV_ROOT/packages/server/dist/server.js" \
      >"${TMPDIR:-/tmp}/claudeview-$PORT.log" 2>&1 &
    sleep 1
    if curl -sf -m 2 "http://localhost:$PORT/api/pulse" >/dev/null 2>&1; then
      echo "claudeview: dashboard → http://localhost:$PORT"
    else
      echo "claudeview: dashboard failed to start (see ${TMPDIR:-/tmp}/claudeview-$PORT.log) — continuing without it" >&2
    fi
  else
    echo "claudeview: not built — run 'pnpm -r build' in $CV_ROOT" >&2
  fi
fi

exec claude --plugin-dir "$CV_ROOT" ${ARGS[@]+"${ARGS[@]}"}
