#!/usr/bin/env bash
#
# claudeview — Claude Code in the current project, with ClaudeView attached.
#
#   claudeview                  # plugin + dashboard + browser tab + --dangerously-skip-permissions
#   claudeview --safe           # ...without skip-permissions, for when you want the prompts
#   claudeview --no-browser     # dashboard, but don't open a tab
#   claudeview --no-dashboard   # plugin only; no server, no browser
#   claudeview --restart        # force a fresh dashboard, even if one is already healthy
#
# Any other flags pass straight through to `claude`.
#
# Note on --dangerously-skip-permissions: it is ON by default here because this is a
# personal, single-operator entrypoint and being prompted for every read on a 30k-LOC repo
# is untenable. It does mean an agent can run anything without asking. `--safe` turns it off
# for one invocation; nothing else about the session changes.
#
set -euo pipefail

# Default to wherever this script actually lives, so the checkout can be moved to another
# machine (or just another directory) without editing anything. CLAUDEVIEW_ROOT still wins.
#
# The symlink walk is load-bearing. If this was linked onto your PATH rather than having the
# checkout's own bin/ added to it, BASH_SOURCE is the *link*, not its target — bash doesn't
# resolve it. Walking up from there lands on the link's parent (~/.local for a
# ~/.local/bin/claudeview link) and we'd refuse to start, pointing at a directory that has
# nothing to do with the checkout.
SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do
  LINK="$(readlink "$SELF")"
  [[ "$LINK" == /* ]] && SELF="$LINK" || SELF="$(cd -P "$(dirname "$SELF")" && pwd)/$LINK"
done
CV_ROOT="${CLAUDEVIEW_ROOT:-$(cd -P "$(dirname "$SELF")/.." && pwd)}"

# The PROJECT, not the directory you happen to be standing in. The port below is a hash of
# this, so if it were just $(pwd) then `claudeview` from src/ and from docs/ would hash to
# different ports and you'd get two dashboards watching one repo. Non-git dirs keep the old
# behaviour, which is the best we can do without a project to anchor to.
REPO="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

if [[ ! -f "$CV_ROOT/.claude-plugin/plugin.json" ]]; then
  echo "claudeview: no plugin at $CV_ROOT (set CLAUDEVIEW_ROOT)" >&2
  exit 1
fi

# One dashboard per project, on a STABLE port derived from the repo path.
#
# Stability matters more than it sounds: a dashboard you can keep in a pinned browser tab is
# one you actually glance at. One whose address moves every session is one you stop opening.
PORT=$(( 7800 + $(printf '%s' "$REPO" | cksum | cut -d' ' -f1) % 180 ))

WANT_DASH=1
WANT_BROWSER=1
SKIP_PERMS=1
WANT_RESTART=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --no-dashboard) WANT_DASH=0 ;;
    --no-browser)   WANT_BROWSER=0 ;;
    --safe)         SKIP_PERMS=0 ;;
    --restart)      WANT_RESTART=1 ;;
    *)              ARGS+=("$a") ;;
  esac
done

[[ "$SKIP_PERMS" == "1" ]] && ARGS+=(--dangerously-skip-permissions)

# Hand the URL to the desktop's default browser and forget about it.
#
# Two things are load-bearing. Detachment: we `exec claude` below, so this process is about to
# be replaced — anything still attached to it dies or, worse, holds the terminal. And silence:
# xdg-open is chatty on stderr about things you cannot act on. A browser that fails to open is
# an annoyance; a launcher that hangs because of one is a bug.
#
# No DISPLAY means no desktop to open a tab on (ssh, tty, container) — printing the URL is
# then the correct and only useful behaviour.
open_browser() {
  local url="$1" opener=""
  if [[ "$WANT_BROWSER" != "1" ]]; then return 0; fi
  if [[ "$(uname -s)" == "Darwin" ]]; then
    opener="open"
  elif [[ -z "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    return 0   # headless: the printed URL is the whole story
  else
    for c in "${BROWSER:-}" xdg-open gio-open sensible-browser x-www-browser; do
      [[ -n "$c" ]] && command -v "$c" >/dev/null 2>&1 && { opener="$c"; break; }
    done
  fi
  [[ -z "$opener" ]] && return 0
  ( setsid "$opener" "$url" >/dev/null 2>&1 & ) 2>/dev/null || true
}

# Ask the dashboard how it is, and DISTINGUISH THE ANSWERS.
#
# The previous version probed with `curl -sf` and treated every non-success as "not running".
# That single conflation cost hours: a dashboard whose store had grown past the 512 MiB string
# ceiling answered every request with HTTP 500, `curl -sf` returned failure, and the launcher
# reported "failed to start" — about a server that was running perfectly and had been for days.
# Restarting could not fix it, so the port got blamed, and the port was never involved.
#
# Echoes one of: up | broken <code> | down
probe() {
  local code
  code="$(curl -s -o /dev/null -m "${2:-2}" -w '%{http_code}' "$1/api/pulse" 2>/dev/null)" || true
  case "$code" in
    200)      echo "up" ;;
    ""|000)   echo "down" ;;          # nothing listening, or no answer within the timeout
    *)        echo "broken $code" ;;  # listening, and telling us it is unwell
  esac
}

# Is the running dashboard executing the code that is on disk right now?
#
# It reports the size:mtime of the server file it LOADED; we compare against the file as it
# is. Equal means current. Anything else — including a server too old to have the endpoint —
# means restart, because a build we cannot identify is exactly the one we should not trust.
SERVER_JS="$CV_ROOT/packages/server/dist/server.js"
is_stale() {
  [[ "$WANT_RESTART" == "1" ]] && return 0
  local remote local_build
  remote="$(curl -s -m 2 "$URL/api/version" 2>/dev/null | sed -n 's/.*"build":"\([^"]*\)".*/\1/p')"
  [[ -z "$remote" ]] && return 0   # no version endpoint at all: predates this check, so old
  local_build="$(stat -c '%s:%.0Y' "$SERVER_JS" 2>/dev/null || stat -f '%z:%m' "$SERVER_JS" 2>/dev/null)"
  # stat(1) reports mtime in whole seconds; the server reports milliseconds. Compare on the
  # second, or every start would look stale and restart a perfectly current dashboard.
  [[ "${remote%:*}:$(( ${remote##*:} / 1000 ))" != "$local_build" ]]
}

# Is this pid one of our dashboards, serving THIS port?
#
# cmdline alone is not enough: you may well have dashboards up for three different projects,
# and killing the wrong one would close somebody else's tab. CV_PORT is how the launcher told
# it which port to serve, so the environment is the authoritative answer.
is_our_dashboard() {
  local pid="$1"
  tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null | grep -q 'packages/server/dist' || return 1
  tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | grep -qx "CV_PORT=$PORT"
}

# Find the dashboard on this port. Asking it is the fast path, NOT the only one.
#
# The first version asked `/api/version` for the pid, which fails on precisely the servers
# this exists to replace: a build older than that endpoint has no route for it, the request
# falls through to the SPA static handler, and it answers 200 with index.html. So the pid was
# never found, nothing was killed, and the respawn died with EADDRINUSE — reported, wrongly
# but plausibly, as "another session started the dashboard first".
#
# A restart mechanism that only works on versions that already have it is no restart mechanism
# at all. So: ask, and if the answer is not a pid, go and look.
find_dashboard_pid() {
  local pid
  pid="$(curl -s -m 2 "$URL/api/version" 2>/dev/null | sed -n 's/.*"pid":\([0-9]*\).*/\1/p')"
  if [[ -n "$pid" ]] && is_our_dashboard "$pid"; then echo "$pid"; return 0; fi

  if [[ -d /proc ]]; then
    for d in /proc/[0-9]*; do
      pid="${d#/proc/}"
      is_our_dashboard "$pid" && { echo "$pid"; return 0; }
    done
  elif command -v lsof >/dev/null 2>&1; then
    # macOS has no /proc. Take the listener on the port, but only if it is a node process,
    # so we still cannot shoot something unrelated.
    pid="$(lsof -ti "tcp:$PORT" -sTCP:LISTEN 2>/dev/null | head -1)"
    [[ -n "$pid" ]] && ps -p "$pid" -o command= 2>/dev/null | grep -q 'packages/server/dist' && { echo "$pid"; return 0; }
  fi
  return 1
}

# Stop the dashboard on this port and wait for the port to actually come free.
#
# Killing by pid rather than by port because we must not shoot an unrelated process that
# happens to be listening — and killing via an HTTP shutdown endpoint is worse: the server
# binds every interface, so that would be a remote kill switch on the LAN.
#
# The wait is not politeness. `kill` returns as soon as the signal is delivered, not when the
# process has exited and released the socket, so spawning immediately races the old server to
# the port and loses with EADDRINUSE.
stop_dashboard() {
  local pid
  pid="$(find_dashboard_pid)" || return 1
  kill "$pid" 2>/dev/null || true
  for _ in $(seq 1 30); do
    kill -0 "$pid" 2>/dev/null || break
    sleep 0.1
  done
  kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
  # And wait for the socket, which can outlive the process by a moment.
  for _ in $(seq 1 20); do
    [[ "$(probe "$URL" 1)" == "down" ]] && return 0
    sleep 0.1
  done
  return 0
}

if [[ "$WANT_DASH" == "1" ]]; then
  URL="http://localhost:$PORT"
  STATE="$(probe "$URL" 1)"

  if [[ "$STATE" == "up" ]] && is_stale; then
    # Running, healthy, and executing code you replaced.
    #
    # A dashboard survives the session that started it, so after `git pull && pnpm -r build`
    # the OLD process is still serving. The launcher probed it, got a healthy 200, said
    # "already up" and attached — so every fix sat on disk, unrunning, with no symptom except
    # the bug you thought you had just fixed still happening. That is an expensive kind of
    # silence, and it cost a debugging round.
    echo "claudeview: dashboard at $URL is running an older build — restarting it"
    if stop_dashboard; then
      STATE="down"
    else
      # Could not find it to stop it: something is serving this port that we cannot identify
      # as ours. Leave it strictly alone and say so, rather than spawning a rival that will
      # only die with EADDRINUSE and be reported as a lost race.
      echo "claudeview: could not identify the process on $PORT — leaving it alone" >&2
      echo "            stop it yourself, or use a different project directory" >&2
    fi
  fi

  if [[ "$STATE" == "up" ]]; then
    # The one-dashboard-per-project case, and the common one: a second `claudeview` in the same
    # repo attaches to the tab that is already open rather than racing to start a rival.
    echo "claudeview: dashboard already up → $URL"
    open_browser "$URL"
  elif [[ "$STATE" == broken* ]]; then
    # Running, and answering with its own diagnosis. Say so, and point at the fix instead of
    # spawning a duplicate that can only die with EADDRINUSE.
    echo "claudeview: dashboard is up at $URL but unhealthy (HTTP ${STATE#broken }) — continuing" >&2
    echo "claudeview: its own error: $(curl -s -m 2 "$URL/api/pulse" | head -c 200)" >&2
    echo "claudeview: if that mentions a string length, the store needs compacting:" >&2
    echo "            cv compact --repo $REPO      # free, local, keeps your history" >&2
  elif [[ -f "$CV_ROOT/packages/server/dist/server.js" ]]; then
    # Detached. Its failure must never block the session it only observes.
    CLAUDE_PROJECT_DIR="$REPO" CV_PORT="$PORT" \
      nohup node "$CV_ROOT/packages/server/dist/server.js" \
      >"${TMPDIR:-/tmp}/claudeview-$PORT.log" 2>&1 &

    # Give it a moment to come up — but NEVER wait on it.
    #
    # This is the dashboard's cardinal rule and I broke it once already: it observes the
    # session, so it must never delay the session. A previous version polled for up to 45
    # seconds so it could print an accurate message, and on a large repo that meant sitting
    # at a blank terminal waiting for a thing you did not ask to wait for. Correct reporting
    # is not worth a second of your time here.
    #
    # So: a short grace period for the common case where boot is fast enough to give a
    # definite answer, then get out of the way and say honestly that it is still starting.
    STATE="down"
    for _ in $(seq 1 6); do
      STATE="$(probe "$URL" 0.5)"
      [[ "$STATE" != "down" ]] && break
      sleep 0.25
    done

    if [[ "$STATE" == "down" ]] && kill -0 $! 2>/dev/null; then
      # Alive, just not finished booting. The browser will connect when it is ready, and the
      # session starts NOW.
      echo "claudeview: dashboard starting in the background → $URL"
      open_browser "$URL"
      STATE="deferred"
    fi

    if [[ "$STATE" == "up" ]]; then
      echo "claudeview: dashboard → $URL"
      open_browser "$URL"
    elif [[ "$STATE" == "deferred" ]]; then
      : # already reported, already opening; the session must not wait
    else
      # Deliberately no browser here: a tab onto a port with nothing behind it is worse than
      # no tab, because it looks like the dashboard is broken rather than absent.
      LOG="${TMPDIR:-/tmp}/claudeview-$PORT.log"
      if grep -q EADDRINUSE "$LOG" 2>/dev/null; then
        # Two sessions started at once and this one lost. That is not an error — the winner is
        # serving the dashboard we wanted, which is exactly the one-per-project behaviour.
        echo "claudeview: another session started the dashboard first → $URL"
        open_browser "$URL"
      else
        echo "claudeview: dashboard failed to start (see $LOG) — continuing without it" >&2
        tail -n 3 "$LOG" 2>/dev/null | sed 's/^/            /' >&2
      fi
    fi
  else
    echo "claudeview: not built — run 'pnpm -r build' in $CV_ROOT" >&2
  fi
fi

exec claude --plugin-dir "$CV_ROOT" ${ARGS[@]+"${ARGS[@]}"}
