node_modules/
dist/
*.tsbuildinfo
.env
.env.*
!.env.example

# ClaudeView's own derived index — a pure function of .claudeview/*.jsonl,
# rebuilt in seconds. Never committed: a binary blob would only buy merge conflicts.
.claudeview/cache/

# Playwright screenshots from local verification
.playwright-mcp/

# Session rollups are per-machine history, not shared knowledge. Flows/decisions/insights
# ARE committed (that is the point); your own session log is not.
.claudeview/sessions.jsonl

# Queued/claimed analysis jobs are local runtime state, not knowledge.
.claudeview/jobs/
